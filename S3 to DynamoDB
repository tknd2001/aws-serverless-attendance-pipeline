#Reads csv from S3, stores them in DynamoDB
from datetime import datetime, timezone
import boto3

dynamodb = boto3.resource("dynamodb")
TABLE_NAME = "AttendanceRecordsV2"
table = dynamodb.Table(TABLE_NAME)


def structure_row(row, source_file_name):
    upload_timestamp = datetime.now(timezone.utc).isoformat()

    item = {
        "StudentID": str(row.get("StudentID", "")).strip(),
        "Date": str(row.get("Date", "")).strip(),
        "StudentName": str(row.get("StudentName", "")).strip(),
        "Course": str(row.get("Course", "")).strip(),
        "Attendance": str(row.get("Attendance", "")).strip(),
        "UploadTimestamp": upload_timestamp,
        "SourceFileName": source_file_name
    }

    return item


def validate_row(item):
    if not item["StudentID"]:
        raise ValueError("StudentID is blank.")

    if not item["Date"]:
        raise ValueError("Date is blank.")

    if not item["StudentName"]:
        raise ValueError("StudentName is blank.")

    if not item["Course"]:
        raise ValueError("Course is blank.")

    if item["Attendance"] not in {"Present", "Absent"}:
        raise ValueError("Attendance must be Present or Absent.")

    datetime.strptime(item["Date"], "%Y-%m-%d")


def process_rows(rows, object_key):
    success_count = 0
    failure_count = 0

    for row_number, row in enumerate(rows, start=2):
        try:
            structured_item = structure_row(row, object_key)
            validate_row(structured_item)
            table.put_item(Item=structured_item)

            success_count += 1
            print(f"Inserted record for StudentID {structured_item['StudentID']} on {structured_item['Date']}")

        except Exception as row_error:
            failure_count += 1
            print(f"Error in row {row_number}: {row_error}")
            print(f"Problem row: {row}")

    print(f"Finished processing file {object_key}")
    print(f"Successful rows: {success_count}")
    print(f"Failed rows: {failure_count}")
