#For moving processed data in DynamoDB to a new folder in the specified bucket's processed folder in S3
import json
import csv
from io import StringIO
from datetime import datetime, timezone
from decimal import Decimal

import boto3
from botocore.exceptions import ClientError

dynamodb = boto3.resource("dynamodb")
s3 = boto3.client("s3")

SOURCE_TABLE_NAME = "AttendanceSummary"
TARGET_BUCKET_NAME = "testing-bucket-gamma-one"
TARGET_PREFIX = "processed/"

source_table = dynamodb.Table(SOURCE_TABLE_NAME)


def lambda_handler(event, context):
    print("Starting export of AttendanceSummary to S3...")
    print(f"Source table: {SOURCE_TABLE_NAME}")
    print(f"Target bucket: {TARGET_BUCKET_NAME}")
    print(f"Target prefix: {TARGET_PREFIX}")
    print(f"Received event: {json.dumps(event)}")

    try:
        verify_table_exists(source_table, SOURCE_TABLE_NAME)

        # Step 1: Read all summary records from DynamoDB
        items = scan_entire_table(source_table)
        print(f"Total summary records fetched: {len(items)}")

        if not items:
            return {
                "statusCode": 200,
                "body": json.dumps({
                    "message": "No records found in AttendanceSummary.",
                    "records_exported": 0
                })
            }

        # Step 2: Convert data into CSV
        csv_content = build_csv(items)

        # Step 3: Create output file name
        timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%d_%H-%M-%S")
        output_key = f"{TARGET_PREFIX}attendance_summary_{timestamp}.csv"

        # Step 4: Upload CSV to S3
        upload_to_s3(TARGET_BUCKET_NAME, output_key, csv_content)

        return {
            "statusCode": 200,
            "body": json.dumps({
                "message": "AttendanceSummary exported successfully to S3.",
                "records_exported": len(items),
                "bucket": TARGET_BUCKET_NAME,
                "object_key": output_key
            })
        }

    except Exception as e:
        print(f"Fatal error: {str(e)}")
        return {
            "statusCode": 500,
            "body": json.dumps({
                "message": "Failed to export AttendanceSummary to S3.",
                "error": str(e)
            })
        }


def verify_table_exists(table, table_name):
    try:
        table.load()
        print(f"Verified table exists: {table_name}")
    except ClientError as e:
        raise Exception(f"Table '{table_name}' not found or not accessible: {str(e)}")


def scan_entire_table(table):
    """
    Scan full DynamoDB table with pagination.
    """
    items = []
    response = table.scan()
    items.extend(response.get("Items", []))

    while "LastEvaluatedKey" in response:
        response = table.scan(ExclusiveStartKey=response["LastEvaluatedKey"])
        items.extend(response.get("Items", []))

    return items


def build_csv(items):
    """
    Convert AttendanceSummary items into CSV text.
    Flatten AttendanceDates and SourceFiles into strings.
    """
    output = StringIO()

    fieldnames = [
        "StudentID",
        "Course",
        "StudentName",
        "TotalClasses",
        "PresentCount",
        "AbsentCount",
        "AttendancePercentage",
        "AttendanceDates",
        "SourceFiles"
    ]

    writer = csv.DictWriter(output, fieldnames=fieldnames)
    writer.writeheader()

    for item in items:
        attendance_dates = item.get("AttendanceDates", [])
        source_files = item.get("SourceFiles", [])

        # Convert complex fields into strings
        attendance_dates_str = json.dumps(convert_decimals(attendance_dates), ensure_ascii=False)
        source_files_str = ", ".join(source_files) if isinstance(source_files, list) else str(source_files)

        row = {
            "StudentID": str(item.get("StudentID", "")),
            "Course": str(item.get("Course", "")),
            "StudentName": str(item.get("StudentName", "")),
            "TotalClasses": convert_decimal_value(item.get("TotalClasses", 0)),
            "PresentCount": convert_decimal_value(item.get("PresentCount", 0)),
            "AbsentCount": convert_decimal_value(item.get("AbsentCount", 0)),
            "AttendancePercentage": convert_decimal_value(item.get("AttendancePercentage", 0)),
            "AttendanceDates": attendance_dates_str,
            "SourceFiles": source_files_str
        }

        writer.writerow(row)

    return output.getvalue()


def upload_to_s3(bucket_name, object_key, content):
    """
    Upload text content to S3.
    """
    try:
        s3.put_object(
            Bucket=bucket_name,
            Key=object_key,
            Body=content.encode("utf-8"),
            ContentType="text/csv"
        )
        print(f"File uploaded to s3://{bucket_name}/{object_key}")
    except ClientError as e:
        raise Exception(f"Failed to upload file to S3: {e}")


def convert_decimal_value(value):
    if isinstance(value, Decimal):
        if value % 1 == 0:
            return int(value)
        return float(value)
    return value


def convert_decimals(obj):
    """
    Recursively convert Decimal values to int/float.
    """
    if isinstance(obj, list):
        return [convert_decimals(x) for x in obj]
    elif isinstance(obj, dict):
        return {k: convert_decimals(v) for k, v in obj.items()}
    elif isinstance(obj, Decimal):
        if obj % 1 == 0:
            return int(obj)
        return float(obj)
    else:
        return obj
